PROJECT_NAME           = "@CMAKE_PROJECT_NAME@"
PROJECT_NUMBER         = "@UFIFO_VERSION_MAJOR@.@UFIFO_VERSION_MINOR@.@UFIFO_VERSION_PATCH@"
OUTPUT_DIRECTORY       = docs
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/inc
OPTIMIZE_OUTPUT_FOR_C  = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
